# ============================================
# Blog MVP - Environment Variables
# ============================================

# --------------------------------------------
# API Keys (Server-side only - DO NOT expose to client)
# These keys are used in Server Actions only
# --------------------------------------------

# Google Places API Key
# Get from: https://developers.google.com/maps/documentation/places/web-service/get-api-key
# Required for: Restaurant place search
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Naver Local Search API Credentials
# Get from: https://developers.naver.com/apps
# Required for: Restaurant place search
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# --------------------------------------------
# AI Provider Settings (Server-side only)
# --------------------------------------------

# AI Provider to use: 'openai' | 'anthropic' | 'mock'
# Default: 'mock' (no API key required)
AI_PROVIDER=mock

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
# Required for: AI draft generation, text correction
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model to use
# Default: 'gpt-4o-mini' (cost-effective, good quality)
# Options: 'gpt-4o', 'gpt-4o-mini', 'gpt-4-turbo'
OPENAI_MODEL=gpt-4o-mini

# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
# Required for: Alternative AI provider
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic Model to use
# Default: 'claude-3-haiku-20240307'
# Options: 'claude-3-opus-20240229', 'claude-3-sonnet-20240229', 'claude-3-haiku-20240307'
ANTHROPIC_MODEL=claude-3-haiku-20240307

# AI Request Timeout (milliseconds)
# Default: 30000 (30 seconds)
AI_TIMEOUT_MS=30000

# --------------------------------------------
# Public Flags (Safe to expose to client)
# --------------------------------------------

# Use mock data instead of real API calls
# Set to "true" for development without API keys
NEXT_PUBLIC_USE_MOCK_PLACES=false

# --------------------------------------------
# Database / Storage (Future use)
# --------------------------------------------

# Database URL (if using external database)
# DATABASE_URL=your_database_url_here

# --------------------------------------------
# Notes
# --------------------------------------------
# 
# IMPORTANT: Never prefix server-side API keys with NEXT_PUBLIC_
# This would expose them to the browser, causing security issues.
#
# The following variables MUST remain server-side only:
# - GOOGLE_MAPS_API_KEY
# - NAVER_CLIENT_ID
# - NAVER_CLIENT_SECRET
# - AI_PROVIDER
# - OPENAI_API_KEY
# - OPENAI_MODEL
# - ANTHROPIC_API_KEY
# - ANTHROPIC_MODEL
# - AI_TIMEOUT_MS
#
# Mock Fallback Behavior:
# 1. If AI_PROVIDER=mock or API key missing → Use deterministic fallback
# 2. If AI call fails/timeout → Use deterministic fallback with warning
# 3. If schema parse fails → Use deterministic fallback
#
# Copy this file to .env.local and fill in your actual values.
