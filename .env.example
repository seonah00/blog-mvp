# ============================================
# Blog MVP - Environment Variables
# ============================================

# --------------------------------------------
# API Keys (Server-side only - DO NOT expose to client)
# These keys are used in Server Actions only
# --------------------------------------------

# Google Places API Key
# Get from: https://developers.google.com/maps/documentation/places/web-service/get-api-key
# Required for: Restaurant place search
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Naver Local Search API Credentials
# Get from: https://developers.naver.com/apps
# Required for: Restaurant place search (Korean restaurants)
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# Kakao Local Search API Key
# Get from: https://developers.kakao.com
# Required for: Restaurant place search (Korean restaurants, better coordinates)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# Perplexity API Key
# Get from: https://www.perplexity.ai/settings/api
# Required for: Web research (optional restaurant information gathering)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# --------------------------------------------
# Restaurant Research Feature Flags (Optional)
# --------------------------------------------

# Primary provider for restaurant search
# Options: 'naver' | 'kakao' | 'google'
# Default: 'naver' (recommended for Korean restaurants)
RESTAURANT_PRIMARY_PROVIDER=naver

# Secondary provider for restaurant search (optional)
# Options: 'naver' | 'kakao' | 'google'
# Default: 'kakao' (set to empty to disable secondary provider)
RESTAURANT_SECONDARY_PROVIDER=kakao

# Enable Kakao Local API
# Set to "false" if Kakao API returns 403 Forbidden (service disabled)
# Naver API will be used as primary source instead
# Default: "true"
RESTAURANT_ENABLE_KAKAO=true

# Enable web research for restaurant information
# Set to "true" to enable Perplexity web research
# Default: "true"
RESTAURANT_ENABLE_WEB_RESEARCH=true

# Web research provider
# Options: 'perplexity'
# Default: 'perplexity'
RESTAURANT_WEB_RESEARCH_PROVIDER=perplexity

# --------------------------------------------
# AI Provider Settings (Server-side only)
# --------------------------------------------

# AI Provider to use: 'openai' | 'anthropic' | 'mock'
# Default: 'mock' (no API key required)
AI_PROVIDER=mock

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
# Required for: AI draft generation, text correction
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model to use
# Default: 'gpt-4o-mini' (cost-effective, good quality)
# Options: 'gpt-4o', 'gpt-4o-mini', 'gpt-4-turbo'
OPENAI_MODEL=gpt-4o-mini

# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
# Required for: Alternative AI provider
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic Model to use
# Default: 'claude-3-haiku-20240307'
# Options: 'claude-3-opus-20240229', 'claude-3-sonnet-20240229', 'claude-3-haiku-20240307'
ANTHROPIC_MODEL=claude-3-haiku-20240307

# --------------------------------------------
# Restaurant Draft AI Configuration (NEW)
# --------------------------------------------

# Restaurant Draft Provider Mode
# Options:
# - 'openai': OpenAI만 사용 (1단계)
# - 'anthropic': Claude만 사용 (1단계)
# - 'openai_then_claude': OpenAI 초안 → Claude 리라이팅 (2단계, 권장)
# Default: 'openai_then_claude'
RESTAURANT_DRAFT_PROVIDER=openai_then_claude

# Enable Claude Rewriting (2단계)
# Set to "false" to disable Claude rewriting even in 'openai_then_claude' mode
# Useful for testing or cost control
# Default: "true" (if ANTHROPIC_API_KEY is set)
RESTAURANT_ENABLE_CLAUDE_REWRITE=true

# OpenAI Model for Restaurant Draft (Stage 1)
# Default: uses OPENAI_MODEL or 'gpt-4o-mini'
# Options: 'gpt-4o', 'gpt-4o-mini'
RESTAURANT_OPENAI_MODEL=gpt-4o-mini

# Claude Model for Restaurant Draft Rewriting (Stage 2)
# Default: uses ANTHROPIC_MODEL or 'claude-3-haiku-20240307'
# Options: 'claude-3-haiku-20240307', 'claude-3-sonnet-20240229'
RESTAURANT_CLAUDE_MODEL=claude-3-haiku-20240307

# AI Request Timeout (milliseconds)
# Default: 30000 (30 seconds)
AI_TIMEOUT_MS=30000

# --------------------------------------------
# Restaurant Research Feature Flags
# --------------------------------------------

# Primary provider for restaurant search
# Options: 'naver' | 'kakao' | 'google'
# Default: 'naver'
RESTAURANT_PRIMARY_PROVIDER=naver

# Secondary provider for restaurant search (optional)
# Options: 'naver' | 'kakao' | 'google'
# Default: 'kakao'
RESTAURANT_SECONDARY_PROVIDER=kakao

# Enable web research for restaurant information
# Set to "true" to enable Perplexity web research
# Default: "true"
RESTAURANT_ENABLE_WEB_RESEARCH=true

# Web research provider
# Options: 'perplexity'
# Default: 'perplexity'
RESTAURANT_WEB_RESEARCH_PROVIDER=perplexity

# --------------------------------------------
# Public Flags (Safe to expose to client)
# --------------------------------------------

# Use mock data instead of real API calls
# Set to "true" for development without API keys
NEXT_PUBLIC_USE_MOCK_PLACES=false

# --------------------------------------------
# Database / Storage (Future use)
# --------------------------------------------

# Database URL (if using external database)
# DATABASE_URL=your_database_url_here

# --------------------------------------------
# Notes
# --------------------------------------------
# 
# IMPORTANT: Never prefix server-side API keys with NEXT_PUBLIC_
# This would expose them to the browser, causing security issues.
#
# The following variables MUST remain server-side only:
# - GOOGLE_MAPS_API_KEY
# - NAVER_CLIENT_ID
# - NAVER_CLIENT_SECRET
# - KAKAO_REST_API_KEY
# - PERPLEXITY_API_KEY
# - AI_PROVIDER
# - OPENAI_API_KEY
# - OPENAI_MODEL
# - ANTHROPIC_API_KEY
# - ANTHROPIC_MODEL
# - AI_TIMEOUT_MS
# - RESTAURANT_PRIMARY_PROVIDER
# - RESTAURANT_SECONDARY_PROVIDER
# - RESTAURANT_ENABLE_WEB_RESEARCH
# - RESTAURANT_WEB_RESEARCH_PROVIDER
#
# Mock Fallback Behavior:
# 1. If AI_PROVIDER=mock or API key missing → Use deterministic fallback
# 2. If AI call fails/timeout → Use deterministic fallback with warning
# 3. If schema parse fails → Use deterministic fallback
#
# Copy this file to .env.local and fill in your actual values.
