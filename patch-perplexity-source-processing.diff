+
+/**
+ * 텍스트 정제 및 핵심 문장 추출
+ */
+function cleanAndExtractKeySentences(text: string): string {
+  if (!text || text.length < 20) return text
+  
+  // bullet point나 번호 제거
+  let cleaned = text
+    .replace(/^[\s]*[-•·\d]+[.)]?\s*/gm, '') // bullet과 숫자 제거
+    .replace(/\n\s*\n/g, ' ') // 빈 줄 제거
+    .replace(/\s+/g, ' ') // 다중 공백 제거
+    .trim()
+  
+  // 너무 길면 첫 2-3문장만 사용
+  const sentences = cleaned.split(/(?<=[.!?])\s+/)
+  if (sentences.length > 3) {
+    return sentences.slice(0, 3).join(' ')
+  }
+  
+  return cleaned
+}
+
+/**
+ * 제목 정제 (클릭베이트 제거)
+ */
+function cleanTitleText(title: string): string {
+  return title
+    .replace(/\s*\|\s*.*$/, '') // 사이트명 제거 (예: "... | Wikipedia")
+    .replace(/\s*-\s*.*$/, '')  // 사이트명 제거 (예: "... - Naver Blog")
+    .replace(/^(\d+\.\s*)+/, '') // 번호 제거
+    .trim()
+}
+
+/**
+ * 핵심 발견 사항 종합
+ */
+function synthesizeKeyFindings(answer: string, results: { processedSnippet: string }[]): string {
+  // answer가 있으면 사용, 없으면 첫 결과의 processedSnippet 사용
+  const baseText = answer || results[0]?.processedSnippet || ''
+  
+  // bullet point 제거하고 문단 형태로
+  return cleanAndExtractKeySentences(baseText)
+}
